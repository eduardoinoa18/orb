# ─── Python cache ─────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.pytest_cache/
*.egg-info/
dist/
build/
*.egg

# ─── Virtual environments ──────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/

# ─── Secrets — NEVER commit these ─────────────────────────────────────────────
.env
.env.*
!.env.example
*.pem
*.key
secrets/
credentials/

# ─── Test / coverage ──────────────────────────────────────────────────────────
.coverage
htmlcov/
coverage.xml
*.log

# ─── OS / editor ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln

# ─── Playwright ───────────────────────────────────────────────────────────────
playwright-report/
test-results/

# ─── Personal / OneDrive artifacts ────────────────────────────────────────────
*.lnk
*.url
~$*
