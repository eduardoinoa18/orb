# ═══════════════════════════════════════════════════════════════════════════════
# ORB PLATFORM — Environment Variables
# ═══════════════════════════════════════════════════════════════════════════════
#
# HOW TO USE THIS FILE
# ────────────────────
# 1. Copy this file:   cp .env.example .env
# 2. Fill in values    (remove the # from lines you want to activate)
# 3. NEVER commit .env to git  (it's already in .gitignore)
#
# RAILWAY DEPLOYMENT
# ──────────────────
# In Railway → your service → Variables, add only the vars marked [REQUIRED].
# Everything else is optional and can be added later via the Integration Hub UI.
#
# REQUIRED = app will not start without this
# OPTIONAL = app starts fine; feature degrades gracefully if missing
# ═══════════════════════════════════════════════════════════════════════════════


# ── CORE PLATFORM ─────────────────────────────────────────────────────────────
# [REQUIRED] Your platform display name
PLATFORM_NAME=ORB

# [REQUIRED] Your domain (no https://, no trailing slash)
# Example: orb.yourdomain.com  or  myapp.up.railway.app
PLATFORM_DOMAIN=

# [REQUIRED] Long random string for JWT signing. Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=

# [REQUIRED] deployment environment
ENVIRONMENT=production


# ── DATABASE (Supabase) ───────────────────────────────────────────────────────
# [REQUIRED] Get from: https://app.supabase.com → Project Settings → API
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...


# ── OWNER IDENTITY ────────────────────────────────────────────────────────────
# [REQUIRED] Your personal contact details (used for briefings & routing)
MY_EMAIL=you@yourdomain.com
MY_PHONE_NUMBER=+1XXXXXXXXXX
MY_BUSINESS_ADDRESS=123 Main St, Miami, FL 33101


# ── AI PROVIDERS ──────────────────────────────────────────────────────────────
# [OPTIONAL] Configure via Integration Hub after deploy, or set here
# Anthropic Claude — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Groq (free, fast for SMS/short tasks) — https://console.groq.com/keys
GROQ_API_KEY=gsk_...

# Mistral — https://console.mistral.ai/api-keys
# MISTRAL_API_KEY=

# Google AI (Gemini) — https://makersuite.google.com/app/apikey
# GOOGLE_AI_API_KEY=


# ── COMMUNICATIONS ────────────────────────────────────────────────────────────
# [OPTIONAL] Twilio SMS/Voice — https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_FROM_NUMBER=+1XXXXXXXXXX

# [OPTIONAL] Bland AI (outbound AI calling) — https://app.bland.ai
BLAND_AI_API_KEY=

# [OPTIONAL] Resend (transactional email) — https://resend.com/api-keys
RESEND_API_KEY=re_...


# ── GOOGLE OAUTH ──────────────────────────────────────────────────────────────
# [OPTIONAL] For Aria calendar/email integration
# Console: https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=xxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...
# Set this to: https://YOUR_DOMAIN/auth/google/callback
GOOGLE_REDIRECT_URI=https://yourapp.up.railway.app/auth/google/callback
# GOOGLE_WORKSPACE_ADMIN_EMAIL=admin@yourdomain.com


# ── PAYMENTS (Stripe) ─────────────────────────────────────────────────────────
# [OPTIONAL] https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
# Get from: Stripe Dashboard → Webhooks → Add endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_...

# Price IDs from Stripe Dashboard → Products
# STRIPE_PRICE_STARTER_MONTHLY=price_...
# STRIPE_PRICE_STARTER_ANNUAL=price_...
# STRIPE_PRICE_PRO_MONTHLY=price_...
# STRIPE_PRICE_PRO_ANNUAL=price_...
# STRIPE_PRICE_FULL_TEAM_MONTHLY=price_...
# STRIPE_PRICE_FULL_TEAM_ANNUAL=price_...


# ── MARKET DATA ───────────────────────────────────────────────────────────────
# [OPTIONAL] For Orion trading agent
# Alpha Vantage (free tier) — https://www.alphavantage.co/support/#api-key
# ALPHA_VANTAGE_API_KEY=

# MarketAux — https://www.marketaux.com
# MARKETAUX_API_KEY=

# TradingView webhook secret (any string you choose, configure in TV alerts)
# TRADINGVIEW_WEBHOOK_SECRET=


# ── SECURITY (auto-generated if blank) ────────────────────────────────────────
# These are generated automatically on first start if left blank.
# For production, explicitly set them:
#   python -c "import secrets; print(secrets.token_hex(32))"
# ENCRYPTION_SECRET=
# SESSION_SECRET=
# EMAIL_WEBHOOK_SECRET=


# ── MONITORING ────────────────────────────────────────────────────────────────
# [OPTIONAL] Sentry error tracking — https://sentry.io
# SENTRY_DSN=https://xxxx@oxxxx.ingest.sentry.io/xxxx


# ── RAILWAY INFRASTRUCTURE ────────────────────────────────────────────────────
# [OPTIONAL] For Sage to inspect Railway deployments
# RAILWAY_API_TOKEN=
# RAILWAY_PROJECT_ID=


# ── FEATURE FLAGS ─────────────────────────────────────────────────────────────
# Briefing: sends morning SMS via Aria at configured time
ARIA_BRIEFING_ENABLED=true
ARIA_BRIEFING_HOUR=7
ARIA_BRIEFING_MINUTE=0
ARIA_BRIEFING_TIMEZONE=America/New_York

# Sage: monitors platform health every 30 min
SAGE_MONITOR_ENABLED=true
SAGE_MONITOR_INTERVAL_MINUTES=30

# Token cost optimization TTL (cache in minutes)
TOKEN_CACHE_TTL_MINUTES=1440

# Computer use agent (experimental)
COMPUTER_USE_ENABLED=false


# ── FRONTEND ──────────────────────────────────────────────────────────────────
# Set these in your orb-landing deployment (Vercel/Railway/Netlify):
# NEXT_PUBLIC_ORB_API_URL=https://yourapp.up.railway.app
# NEXT_PUBLIC_STRIPE_PK=pk_live_...
